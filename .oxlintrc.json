{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"categories": {
		"correctness": "error",
		"suspicious": "warn",
		"perf": "warn"
	},
	"plugins": ["typescript", "oxc", "unicorn", "import"],
	"jsPlugins": [
		{
			"name": "test-guardrails",
			"specifier": "./tools/eslint-plugin-test-guardrails.mjs"
		},
		{
			"name": "code-quality",
			"specifier": "./tools/eslint-plugin-code-quality.mjs"
		},
		{
			"name": "comment-quality",
			"specifier": "./tools/eslint-plugin-comment-quality.mjs"
		}
	],
	"rules": {
		"no-console": "off",
		"no-await-in-loop": "off",
		"import/no-unassigned-import": "off",
		"unicorn/no-null": "off",
		"unicorn/prefer-event-target": "off",
		"unicorn/prefer-top-level-await": "off",
		"unicorn/no-static-only-class": "off",
		"unicorn/prefer-global-this": "off",
		"unicorn/consistent-function-scoping": "off",
		"code-quality/no-double-type-assertion": "error",
		"code-quality/no-console-only-catch": "warn",
		"code-quality/no-redundant-boolean-return": "warn",
		"code-quality/no-em-dash": "warn",
		"code-quality/no-as-any-assertion": "warn",
		"comment-quality/no-obvious-comment": "warn",
		"comment-quality/no-narrator-comment": "warn",
		"comment-quality/no-section-divider": "warn",
		"comment-quality/no-placeholder-comment": "warn",
		"comment-quality/no-hedging-comment": "warn"
	},
	"overrides": [
		{
			"files": ["packages/*/test/**/*.ts"],
			"rules": {
				"code-quality/no-double-type-assertion": "off",
				"comment-quality/no-section-divider": "off",
				"test-guardrails/no-browser-pause": "error"
			}
		},
		{
			"files": ["packages/*/test/e2e/**/*.ts", "packages/*/test/flp/**/*.ts"],
			"rules": {
				"test-guardrails/no-hard-wait": "error"
			}
		}
	],
	"ignorePatterns": ["**/dist/**", "**/node_modules/**"]
}
