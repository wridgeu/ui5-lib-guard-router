{
	"_version": "2.0.0",
	"sap.app": {
		"id": "demo.app",
		"type": "application",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"title": "UI5 Enhanced Router Demo",
		"crossNavigation": {
			"inbounds": {
				"guarddemo-display": {
					"semanticObject": "guarddemo",
					"action": "display",
					"title": "UI5 Enhanced Router Demo",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		},
		"dataSources": {
			"auth": {
				"type": "JSON",
				"uri": "model/auth.json"
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"dependencies": {
			"minUI5Version": "1.144.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"ui5.guard.router": {}
			}
		},
		"models": {
			"auth": {
				"type": "sap.ui.model.json.JSONModel",
				"dataSource": "auth"
			}
		},
		"rootView": {
			"viewName": "demo.app.view.App",
			"type": "XML",
			"id": "appView"
		},
		"routing": {
			"config": {
				"routerClass": "ui5.guard.router.Router",
				"type": "View",
				"viewType": "XML",
				"path": "demo.app.view",
				"controlId": "appContainer",
				"controlAggregation": "pages",
				"bypassed": {
					"target": "notFound"
				},
				"guardRouter": {
					"unknownRouteRegistration": "warn",
					"inheritance": "pattern-tree",
					"guards": {
						"*": ["guards.navigationLogger"],
						"blocked": ["guards.blockedGuard"],
						"forbidden": ["guards.forbiddenGuard"],
						"protected": {
							"leave": ["guards.dirtyFormGuard"]
						}
					},
					"routeMeta": {
						"employees": { "section": "hr", "requiresAuth": true },
						"employee": { "detail": true }
					}
				}
			},
			"routes": [
				{
					"name": "home",
					"pattern": "",
					"target": "home"
				},
				{
					"name": "protected",
					"pattern": "protected",
					"target": "protected"
				},
				{
					"name": "blocked",
					"pattern": "blocked",
					"target": "blocked"
				},
				{
					"name": "forbidden",
					"pattern": "forbidden",
					"target": "forbidden"
				},
				{
					"name": "admin",
					"pattern": "admin",
					"target": "admin"
				},
				{
					"name": "employees",
					"pattern": "employees",
					"target": "employees"
				},
				{
					"name": "employee",
					"pattern": "employees/{id}",
					"target": "employee"
				}
			],
			"targets": {
				"home": {
					"name": "Home",
					"id": "homeView",
					"level": 1
				},
				"protected": {
					"name": "Protected",
					"id": "protectedView",
					"level": 2
				},
				"blocked": {
					"name": "Blocked",
					"id": "blockedView",
					"level": 2
				},
				"forbidden": {
					"name": "Forbidden",
					"id": "forbiddenView",
					"level": 2
				},
				"notFound": {
					"name": "NotFound",
					"id": "notFoundView",
					"level": 3
				},
				"admin": {
					"name": "Admin",
					"id": "adminView",
					"level": 2
				},
				"employees": {
					"name": "Employees",
					"id": "employeesView",
					"level": 2,
					"transition": "show"
				},
				"employee": {
					"name": "Employee",
					"id": "employeeView",
					"level": 3,
					"transition": "show"
				}
			}
		}
	}
}
