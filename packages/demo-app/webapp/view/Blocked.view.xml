<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	controllerName="demo.app.controller.Blocked">
	<Page id="blockedPage" title="Blocked Page" titleAlignment="Center">
		<content>
			<VBox class="sapUiMediumMargin" alignItems="Start">
				<MessageStrip
					text="You should never see this page. The guard always blocks before navigation commits."
					type="Error"
					showIcon="true" />
			</VBox>
		</content>
	</Page>
</mvc:View>
