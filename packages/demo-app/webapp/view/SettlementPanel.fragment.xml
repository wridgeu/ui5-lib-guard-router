<core:FragmentDefinition
	xmlns:core="sap.ui.core"
	xmlns="sap.m">
	<VBox renderType="Bare">
		<Label text="Last Settlement" />
		<ObjectStatus
			id="settlementStatus"
			text="{runtime>/lastSettlementStatus}"
			state="{runtime>/lastSettlementState}"
			class="sapUiTinyMarginBottom" />
		<HBox wrap="Wrap" renderType="Bare">
			<VBox width="9.5rem" renderType="Bare" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
				<Label text="Route" />
				<Text id="settlementRouteText" text="{runtime>/lastSettlementRoute}" />
			</VBox>
			<VBox width="10rem" renderType="Bare" class="sapUiTinyMarginBottom">
				<Label text="Hash" />
				<Text id="settlementHashText" text="{runtime>/lastSettlementHash}" />
				<Text
					id="settlementHashTechnicalText"
					text="{= 'Technical: ' + ${runtime>/lastSettlementHashTechnical}}"
					wrapping="true" />
			</VBox>
		</HBox>
	</VBox>
</core:FragmentDefinition>
