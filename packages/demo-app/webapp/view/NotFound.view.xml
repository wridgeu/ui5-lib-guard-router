<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns="sap.m"
	controllerName="demo.app.controller.NotFound">
	<Page id="notFoundPage" title="Not Found" titleAlignment="Center" showNavButton="true" navButtonPress=".onNavHome">
		<content>
			<VBox class="sapUiMediumMargin" alignItems="Stretch" renderType="Bare">
				<IllustratedMessage
					illustrationType="PageNotFound"
					title="Page Not Found"
					description="The requested page does not exist in this demo application.">
					<additionalContent>
						<Button text="Go to Home" type="Emphasized" press=".onNavHome" />
					</additionalContent>
				</IllustratedMessage>
				<Panel headerText="Last Settlement" class="sapUiMediumMarginTop">
					<content>
						<core:Fragment fragmentName="demo.app.view.SettlementPanel" type="XML" />
					</content>
				</Panel>
			</VBox>
		</content>
	</Page>
</mvc:View>
