{
	"name": "ui5-lib-guard-router-monorepo",
	"private": true,
	"author": "Marco Beier",
	"repository": {
		"type": "git",
		"url": "https://github.com/wridgeu/ui5-lib-guard-router.git"
	},
	"engines": {
		"node": ">=22"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"clean": "npm run clean --workspaces",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"lint": "oxlint packages/ scripts/ tools/ --tsconfig tsconfig.base.json --import-plugin --deny-warnings",
		"lint:fix": "oxlint packages/ scripts/ tools/ --tsconfig tsconfig.base.json --import-plugin --fix",
		"check": "npm run fmt:check && npm run lint && npm run typecheck",
		"typecheck": "tsc --noEmit -p packages/lib/tsconfig.json && tsc --noEmit -p packages/lib/tsconfig.test.json && tsc --noEmit -p packages/demo-app/tsconfig.json && tsc --noEmit -p packages/demo-app/tsconfig.test.json",
		"build": "npm run build --workspace=packages/lib",
		"start": "npm start --workspace=packages/demo-app",
		"start:flp": "npm run start:flp --workspace=packages/demo-app",
		"start:lib": "npm start --workspace=packages/lib",
		"start:lib:compat:120": "npm run start:compat:120 --workspace=packages/lib",
		"start:lib:compat:120:test": "npm run start:compat:120 --workspace=packages/lib -- --port 8082",
		"serve:demo": "npm run serve --workspace=packages/demo-app",
		"serve:demo:flp": "npm run serve:flp --workspace=packages/demo-app",
		"serve:demo:test": "npm run serve --workspace=packages/demo-app -- --port 8081",
		"serve:demo:flp:test": "npm run serve:flp --workspace=packages/demo-app -- --port 8083",
		"wdio:qunit": "wdio run packages/lib/test/wdio-qunit.conf.ts",
		"wdio:e2e": "wdio run packages/demo-app/test/wdio.conf.ts",
		"wdio:e2e:flp": "wdio run packages/demo-app/test/wdio-flp.conf.ts",
		"test": "npm run test:qunit && npm run test:e2e",
		"test:full": "npm run test:qunit && npm run test:qunit:compat:120 && npm run test:e2e && npm run test:e2e:flp",
		"test:qunit": "node ./scripts/run-with-server.mjs --ready-url http://localhost:8080 --server-script start:lib --test-script wdio:qunit",
		"test:qunit:compat:120": "node ./scripts/run-with-server.mjs --ready-url http://localhost:8082 --server-script start:lib:compat:120:test --test-script wdio:qunit --test-base-url http://localhost:8082",
		"test:e2e": "node ./scripts/run-with-server.mjs --ready-url http://localhost:8081 --server-script serve:demo:test --test-script wdio:e2e --test-base-url http://localhost:8081/index.html",
		"test:e2e:flp": "node ./scripts/run-with-server.mjs --ready-url http://localhost:8083/test/flp.html?sap-ui-xx-viewCache=false --server-script serve:demo:flp:test --test-script wdio:e2e:flp --test-base-url http://localhost:8083/test/flp.html?sap-ui-xx-viewCache=false#app-preview",
		"pack:smoke": "node ./scripts/pack-smoke.mjs",
		"pack:check": "npm run pack:check --workspace=packages/lib && npm run pack:smoke",
		"vendor:openui5-router-tests": "node ./scripts/vendor-openui5-router-tests.mjs",
		"verify:openui5-router-vendor": "node ./scripts/verify-openui5-router-vendor.mjs",
		"release:plan": "node ./scripts/release-plan.mjs",
		"commitlint": "commitlint --last",
		"prepare": "husky"
	},
	"lint-staged": {
		"{packages,scripts,tools}/**/*.{ts,js,mjs}": [
			"oxlint --fix --tsconfig tsconfig.base.json --import-plugin --deny-warnings",
			"oxfmt"
		],
		"*.{json,md,yaml,yml}": "oxfmt"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@openui5/types": "^1.144.0",
		"@sapui5/types": "^1.144.0",
		"@types/mocha": "^10.0.0",
		"@types/sinon": "^21.0.0",
		"@wdio/cli": "^9.0.0",
		"@wdio/local-runner": "^9.0.0",
		"@wdio/mocha-framework": "^9.0.0",
		"@wdio/spec-reporter": "^9.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"release-please": "^17.3.0",
		"rimraf": "^6.0.0",
		"typescript": "~6.0.0",
		"wdio-qunit-service": "^2.0.0",
		"wdio-ui5-service": "^3.0.0"
	}
}
